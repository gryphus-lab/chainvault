<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:flowable="http://flowable.org/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:design="http://flowable.org/design" typeLanguage="http://www.w3.org/2001/XMLSchema" expressionLanguage="http://www.w3.org/1999/XPath" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Flowable Design" exporterVersion="2025.1.03" design:palette="flowable-work-process-palette">
  <process id="chainvault" name="ChainVault Process" isExecutable="true">
    <extensionElements>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2026-02-25T12:07:07.166Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2026-03-15T20:20:56.225Z]]></design:modificationdate>
    </extensionElements>
    <serviceTask id="Task_HandleError" name="Handle Error" flowable:delegateExpression="${handleError}">
      <documentation>Handle any errors thrown by process tasks and log exception details</documentation>
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Task_Send" name="Upload to Target Archive" flowable:delegateExpression="${uploadSftp}">
      <documentation>Upload the following files to target archive via SFTP:
- chain of custody ZIP archive
- merged PDF file (if it exists)
- target archive metadata</documentation>
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Task_Extract" name="Extract and Hash" flowable:delegateExpression="${extractAndHash}">
      <documentation>Call Source Archive REST API for extracting metadata and documents by id, and hash the contents</documentation>
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Task_Transform" name="Transform Metadata" flowable:delegateExpression="${transformMetadata}">
      <documentation>Transform source metadata into target archive XML metadata format containing the following:
- Document metadata
- Original payload hash
- Chain of Custody ZIP hash
- Merged PDF hash
- Migration provenance (migration timestamp, tool version, operator, original page hashes)
- Additional fields e.g. OCR results</documentation>
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Task_Merge" name="Merge to PDF" flowable:delegateExpression="${mergePdf}">
      <documentation>Merge source files into a multipage PDF file</documentation>
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Task_Prepare" name="Prepare Files" flowable:delegateExpression="${prepareFiles}">
      <documentation>Create Chain of Custody zip file containing the following:
- original source files with preserved sequence
- JSON manifest of source metadata and hashes with timestamp</documentation>
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Task_Sign" name="Sign Payload" flowable:delegateExpression="${signDocument}">
      <documentation>Validate and sign payload</documentation>
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Task_InitVars" name="Async Init" flowable:async="true" flowable:asyncLeave="true" flowable:delegateExpression="${asyncInitVars}">
      <documentation>Asynchronous initialization of workflow</documentation>
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="Task_OCR" name="Perform OCR" flowable:delegateExpression="${performOcr}">
      <documentation>Perform OCR on source files using Tesseract and store OCR results</documentation>
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <exclusiveGateway id="Check_Payload_Exists" name="Pages Exist?">
      <extensionElements>
        <design:stencilid><![CDATA[Exclusive_Databased_Gateway]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </exclusiveGateway>
    <exclusiveGateway id="Exclusive_Databased_Gateway_18" name="Payload Exists?">
      <extensionElements>
        <design:stencilid><![CDATA[Exclusive_Databased_Gateway]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </exclusiveGateway>
    <startEvent id="StartEvent_1" name="Start Migration" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:work-form-field-validation><![CDATA[false]]></flowable:work-form-field-validation>
        <design:stencilid><![CDATA[StartNoneEvent]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </startEvent>
    <endEvent id="EndEvent_Success" name="Migration Completed">
      <extensionElements>
        <design:stencilid><![CDATA[EndNoneEvent]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </endEvent>
    <endEvent id="EndEvent_Failed" name="Migration Failed">
      <extensionElements>
        <design:stencilid><![CDATA[EndNoneEvent]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </endEvent>
    <sequenceFlow id="Flow_ToFailedEnd" sourceRef="Task_HandleError" targetRef="EndEvent_Failed">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <boundaryEvent id="BoundaryError_Send" name="Upload Error" attachedToRef="Task_Send">
