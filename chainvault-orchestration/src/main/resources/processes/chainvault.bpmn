      <errorEventDefinition errorRef="EXTRACTION_FAILED"></errorEventDefinition>
    </boundaryEvent>
    <sequenceFlow id="SequenceFlow_2" sourceRef="BoundaryError_Extract" targetRef="Task_HandleError">
